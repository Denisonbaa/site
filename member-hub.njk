<!-- ACTION CARDS -->
<section class="actions-section">
  <div class="section-header">
    <div class="section-label">Take Action</div>
    <h2 class="section-title">Four Ways to Show Up</h2>
  </div>
  <div class="action-grid">
    <div class="action-card">
      <div class="action-num">01</div>
      <h3>Join the BAA</h3>
      <p>Official membership connects you to the network, keeps you informed, and makes you part of the organized voice of Black Denisonians.</p>
      <a href="mailto:baaDenison@denison.edu?subject=BAA%20Membership" class="action-btn">Become a Member</a>
    </div>
    <div class="action-card">
      <div class="action-num">02</div>
      <h3>Make a Gift</h3>
      <p>Contribute to our Scholarship Fund through our Donor-Advised Fund. Every dollar goes directly to Black students at Denison.</p>
      <a href="mailto:baaDenison@denison.edu?subject=Scholarship%20Gift" class="action-btn">Give Now</a>
    </div>
    <div class="action-card">
      <div class="action-num">03</div>
      <h3>Join a Committee</h3>
      <p>Our committees are where the real work happens. Scholarship, Communications, Community Engagement — pick your lane and get to work.</p>
      <a href="#committees" class="action-btn">See Committees</a>
    </div>
    <div class="action-card">
      <div class="action-num">04</div>
      <h3>Mentor a Student</h3>
      <p>Connect with a current Black Denisonian student. Share your path. Open a door. It matters more than you know.</p>
      <a href="mailto:baaDenison@denison.edu?subject=Mentorship" class="action-btn">Sign Up to Mentor</a>
    </div>
  </div>
</section>

<!-- COMMITTEES -->
<section class="committees-section" id="committees">
  <div class="section-header">
