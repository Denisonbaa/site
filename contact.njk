<!-- PAGE HERO -->
<section class="page-hero">
  <div class="page-eyebrow">Denison University · Black Alumni Association</div>
  <h1 class="page-title">Contact</h1>
  <p class="page-subtitle">Get in touch with the BAA</p>
</section>

<!-- CONTACT CARDS -->
<div class="contact-section">
  <div class="contact-grid">
    <div class="contact-card">
      <div class="card-label">General Inquiries</div>
      <h2 class="card-title">{{ card1Title }}</h2>
      <p class="card-body">{{ card1Body }}</p>
      <a href="mailto:{{ card1Email }}" class="email-link">{{ card1Email }}</a>
      <div class="email-note">{{ card1Note }}</div>
    </div>
    <div class="contact-card">
      <div class="card-label">Executive Office</div>
      <h2 class="card-title">{{ card2Title }}</h2>
      <p class="card-body">{{ card2Body }}</p>
      <a href="mailto:{{ card2Email }}" class="email-link">{{ card2Email }}</a>
      <div class="email-note">{{ card2Note }}</div>
    </div>
  </div>
</div>

