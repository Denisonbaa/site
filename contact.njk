      </div>
      <a href="https://docs.google.com/forms/d/e/1FAIpQLScsJDi2Z_uQPb_hf_DWH128lplpstwqKlnwfs0Bxkn2MCTeDQ/viewform" class="quick-btn" target="_blank" rel="noopener">Get Involved</a>
    </div>
    <div class="quick-card">
      <div>
